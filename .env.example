# OSS Research MCP — environment variables (all optional)

# Optional GitHub personal access token. Increases rate limits.
# Without it the server still works against public repositories at lower limits.
# Read from this env var ONLY. Never written to logs, cache, or tool output.
GITHUB_TOKEN=

# Transport: "stdio" (default) or "http".
OSS_MCP_TRANSPORT=stdio

# Port used by the optional Streamable HTTP transport.
OSS_MCP_PORT=7345

# Enable response caching (true/false).
OSS_MCP_CACHE_ENABLED=true

# Cache file location (SQLite). "~" is expanded to the user home directory.
# If better-sqlite3 is unavailable, the server falls back to an in-memory cache.
OSS_MCP_CACHE_PATH=~/.oss-research-mcp/cache.sqlite

# Cache time-to-live in hours.
OSS_MCP_CACHE_TTL_HOURS=24

# Optional DeepWiki adapter (external remote service mcp.deepwiki.com).
# Disabled by default. Set to true to enable it and allow that host.
OSS_MCP_DEEPWIKI_ENABLED=false

# Maximum number of search results returned by default.
OSS_MCP_MAX_RESULTS=20

# HTTP request timeout in milliseconds for outbound GitHub/DeepWiki calls.
OSS_MCP_REQUEST_TIMEOUT_MS=15000

# Log level: debug | info | warn | error. Logs are written to stderr only.
OSS_MCP_LOG_LEVEL=info
